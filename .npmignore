# .npmignore
# Development files
artifacts/
benchmarks/
bindings/
docs/
examples/
plans/
scripts/
dif/

test/
# Exclude Rust source & build artifacts, keep binary
native/target/
# ✅ Keep native binary
!native/target/release/*.node
!native/target/x86_64-pc-windows-msvc/release/*.node

# Source files (should be compiled)
packages/*/src/
packages/*/test/
packages/*/tests/
packages/*/tsconfig.json
packages/*/vitest.config.ts
packages/*/tsup.config.ts

# ✅ EXCLUDE intermediate package dist folders — only root dist/ should be published
packages/*/dist/

# Build artifacts (keep only dist)
# *.map diinclude supaya user bisa debug → tidak di-exclude
**/*.tsbuildinfo

# Configuration files
*.config.js
*.config.ts
*.config.mjs
*.config.json
!tailwind-styled.config.json
.oxlintrc.json
biome.json
demo-cli-config.yml
tokens.sync.json

# Git and IDE
.git/
.github/
.vscode/
.gitignore
.gitattributes
.npmrc

# CI/CD
.circleci/
.travis.yml

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp

# Coverage
coverage/
.nyc_output/

# Environment files
.env
.env.local
.env.*.local

# Package manager locks (optional, depending on your strategy)
package-lock.json
yarn.lock
pnpm-lock.yaml
node_modules
SUPPORT.md
SETUP.md
RELEASE.md
.cache
.kilo
ANNOUNCEMENT.md
CHANGELOG.md
CONTRIBUTING.md

dist/*.map
dist/*.js.map
dist/*.mjs.map