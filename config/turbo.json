{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "@tailwind-styled/studio-desktop#build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist-electron/**"
      ]
    },
    "build:release": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "build:dev": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "outputs": [
        "artifacts/template-test-report.json"
      ],
      "cache": false
    },
    "check": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "pack:check": {
      "dependsOn": [
        "build"
      ],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "build:fast": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    }
  }
}