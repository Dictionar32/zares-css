{
  "name": "@tailwind-styled/svelte",
  "version": "5.0.4",
  "description": "Svelte 4/5 adapter for tailwind-styled-v4 \u2014 cv(), tw(), and use:styled action",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "check": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "pack:check": "node ../../scripts/check-pack-artifacts.mjs packages/presentation/svelte",
    "test": "node --test __tests__/*.test.mjs",
    "test:watch": "node --test --watch __tests__/*.test.mjs"
  },
   "peerDependencies": {
     "svelte": ">=4.0.0"
   },
   "devDependencies": {
     "svelte": "^5.0.0",
     "tsup": "^8.0.0",
     "typescript": "^6"
   },
  "keywords": [
    "tailwind",
    "svelte",
    "svelte5",
    "styled-components",
    "variants",
    "css"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
   "dependencies": {
     "@tailwind-styled/core": "^5.0.4",
     "@tailwind-styled/shared": "^5.0.4",
     "inversify": "^8.1.0",
     "reflect-metadata": "^0.2.2",
     "zod": "^4.3.6"
   }
}
