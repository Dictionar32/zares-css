{
  "name": "@tailwind-styled/vue",
  "version": "5.0.4",
  "description": "Vue 3 adapter for tailwind-styled-v4 \u2014 tw() components with variants",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "pack:check": "node ../../scripts/check-pack-artifacts.mjs packages/presentation/vue",
    "test": "node --test __tests__/*.test.mjs",
    "test:watch": "node --test --watch __tests__/*.test.mjs"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6",
    "vue": "^3.4.0"
  },
  "keywords": [
    "tailwind",
    "vue",
    "vue3",
    "styled-components",
    "variants",
    "css"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/tailwind-styled-v4"
  },
  "dependencies": {
    "@tailwind-styled/core": "^5.0.4",
    "@tailwind-styled/shared": "^5.0.4",
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  }
}