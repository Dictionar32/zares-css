{
  "name": "@tailwind-styled/rspack",
  "version": "0.2.0",
  "description": "Rspack adapter for tailwind-styled-v4 — loader + plugin",
  "author": "Dictionar32",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "import": "./dist/loader.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "@rspack/core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": true
    }
  },
  "dependencies": {
    "@tailwind-styled/compiler": "^0.2.0",
    "@tailwind-styled/engine": "^0.2.0",
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^6"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts src/loader.ts --format esm --out-dir dist --watch --external typescript",
    "check": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "pack:check": "node ../../scripts/check-pack-artifacts.mjs packages/presentation/rspack",
    "test": "node --test tests/*.test.mjs",
    "test:watch": "node --test --watch tests/*.test.mjs"
  }
}
