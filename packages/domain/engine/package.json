{
  "name": "@tailwind-styled/engine",
  "version": "0.2.0",
  "description": "Unified build engine for tailwind-styled-v4",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@tailwind-styled/analyzer": "^0.2.0",
    "@tailwind-styled/compiler": "^0.2.0",
    "@tailwind-styled/scanner": "^0.2.0",
    "@tailwind-styled/shared": "^0.2.0",
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8",
    "typescript": "^6"
  },
  "scripts": {
    "build": "tsup",
    "build:dev": "tsup --config tsup.config.ts --sourcemap --watch",
    "build:release": "tsup --config tsup.config.ts --no-sourcemap",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsup --config tsup.config.ts --watch",
    "pack:check": "node ../../scripts/check-pack-artifacts.mjs packages/domain/engine",
    "test:watch": "node --test --watch tests/*.test.mjs",
    "test": "node --test tests/*.test.mjs"
  }
}
