{
  "name": "@tailwind-styled/scanner",
  "version": "0.2.0",
  "description": "Standalone class scanner for tailwind-styled-v4",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@tailwind-styled/shared": "^0.2.0",
    "@tailwind-styled/syntax": "^0.2.0",
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^6"
  },
  "scripts": {
    "build": "tsup",
    "build:dev": "tsup --sourcemap --watch",
    "build:release": "tsup --no-sourcemap",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsup --watch",
    "pack:check": "node ../../scripts/check-pack-artifacts.mjs packages/domain/scanner",
    "test": "node --test tests/*.test.mjs",
    "test:watch": "node --test --watch tests/*.test.mjs"
  }
}
