{
  "name": "@tailwind-styled/theme",
  "version": "5.0.4",
  "description": "Theme engine and live token engine for tailwind-styled-v5",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./live-tokens": {
      "types": "./dist/liveTokens.d.ts",
      "import": "./dist/liveTokens.js",
      "require": "./dist/liveTokens.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test:watch": "node --test --watch tests/*.test.mjs",
    "dev": "tsup --watch",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "pack:check": "node ../../scripts/check-pack-artifacts.mjs packages/domain/theme",
    "test": "node --test tests/*.test.mjs"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "devDependencies": {
    "@types/react": "^19",
    "tsup": "^8",
    "typescript": "^6"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@tailwind-styled/shared": "^5.0.4",
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  }
}