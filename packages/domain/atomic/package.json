{
  "name": "@tailwind-styled/atomic",
  "version": "0.2.0",
  "description": "Atomic CSS generation for tailwind-styled-v4",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@tailwind-styled/compiler": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8",
    "typescript": "^6"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check": "tsc --noEmit",
    "test:watch": "node --test --watch test/*.test.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "pack:check": "node ../../scripts/check-pack-artifacts.mjs packages/domain/atomic",
    "test": "node --test __tests__/*.test.mjs"
  },
  "dependencies": {
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  }
}
