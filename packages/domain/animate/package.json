{
  "name": "@tailwind-styled/animate",
  "version": "5.0.4",
  "description": "Native-backed async animation DSL for tailwind-styled-v4",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@tailwind-styled/analyzer": "^5.0.4",
    "@tailwind-styled/shared": "^5.0.4",
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "pack:check": "node ../../scripts/check-pack-artifacts.mjs packages/domain/animate",
    "test": "node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^6"
  }
}