{
  "name": "@tailwind-styled/plugin-registry",
  "version": "5.0.4",
  "description": "Plugin discovery and install helper for the tailwind-styled v5 ecosystem",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tw-plugin": "./dist/cli.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "registry.json"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --out-dir dist --clean --external typescript",
    "dev": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --out-dir dist --watch --external typescript",
    "check": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "pack:check": "node ../../scripts/check-pack-artifacts.mjs packages/domain/plugin-registry",
    "test": "node --test __tests__/*.test.mjs",
    "test:watch": "node --test --watch __tests__/*.test.mjs",
    "benchmark": "node benchmark/index.mjs",
    "benchmark:json": "node benchmark/index.mjs --json"
  },
  "dependencies": {
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  }
}