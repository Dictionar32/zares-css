{
  "name": "@tailwind-styled/devtools",
  "version": "5.0.4",
  "description": "Visual debug overlay for tailwind-styled-v4 \u2014 zero production impact",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check": "tsc --noEmit",
    "test:watch": "node --test --watch test/*.test.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "pack:check": "node ../../scripts/check-pack-artifacts.mjs packages/infrastructure/devtools",
    "test": "node --test tests/*.test.mjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "tsup": "^8",
    "typescript": "^6"
  },
  "dependencies": {
    "@tailwind-styled/analyzer": "^5.0.4",
    "@tailwind-styled/scanner": "^5.0.4",
    "@tailwind-styled/shared": "^5.0.4",
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  }
}