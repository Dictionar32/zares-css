{
  "name": "@tailwind-styled/storybook-addon",
  "version": "5.0.4",
  "description": "Storybook helpers for tailwind-styled variant previews",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist --clean --external typescript",
    "dev": "tsup src/index.ts --format cjs,esm --dts --out-dir dist --watch --external typescript",
    "check": "tsc --noEmit",
    "test:watch": "node --test --watch test/*.test.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "pack:check": "node ../../scripts/check-pack-artifacts.mjs packages/infrastructure/storybook-addon",
    "test": "node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^6"
  },
  "dependencies": {
    "@tailwind-styled/shared": "^5.0.4",
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  }
}