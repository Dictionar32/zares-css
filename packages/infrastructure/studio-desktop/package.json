{
  "name": "@tailwind-styled/studio-desktop",
  "version": "5.0.4",
  "description": "tailwind-styled Studio — Desktop app (Electron)",
  "private": true,
  "author": "Dictionar32",
  "license": "MIT",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron . --dev || echo \"[studio] Install electron: npm install -D electron\"",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --mac --win --linux",
    "build": "electron-builder --dir",
    "check": "tsc --noEmit",
    "test": "echo \"Studio desktop tests require Electron — run: npm run start\"",
    "clean": "node -e \"require('node:fs').rmSync('dist-electron',{recursive:true,force:true})\"",
    "pack:check": "echo \"Studio desktop pack uses electron-builder\"",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "package:all": "electron-builder --mac --win --linux",
    "pack": "electron-builder --dir",
    "postinstall": "echo \"Run: npm run dev to start Studio Desktop\""
  },
  "build": {
    "appId": "dev.tailwind-styled.studio",
    "productName": "tailwind-styled Studio",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "src/**/*",
      "!src/**/*.test.*"
    ],
    "extraResources": [
      {
        "from": "../../../scripts/v45/studio.mjs",
        "to": "scripts/v45/studio.mjs"
      },
      {
        "from": "../../../scripts/v45/ai.mjs",
        "to": "scripts/v45/ai.mjs"
      },
      {
        "from": "../../../scripts/v49/split-routes.mjs",
        "to": "scripts/v49/split-routes.mjs"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "your-org",
      "repo": "tailwind-styled-v4"
    }
  },
  "dependencies": {
    "@tailwind-styled/engine": "^5.0.4",
    "@tailwind-styled/scanner": "^5.0.4",
    "@tailwind-styled/shared": "^5.0.4",
    "electron-updater": "^6.0.0",
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "electron": "35.7.5",
    "electron-builder": "26.8.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
