{
  "name": "@tailwind-styled/dashboard",
  "version": "5.0.4",
  "description": "Performance dashboard for benchmark and runtime metrics",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist --clean",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsx src/server.ts",
    "pack:check": "node ../../scripts/check-pack-artifacts.mjs packages/infrastructure/dashboard",
    "start": "tsx src/server.ts",
    "test:watch": "node --test --watch test/*.test.mjs",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^6"
  }
}