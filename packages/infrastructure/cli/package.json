{
  "name": "create-tailwind-styled",
  "version": "0.2.0",
  "description": "CLI scaffolding tool — npx create-tailwind-styled",
  "license": "MIT",
  "type": "module",
  "module": "./dist/api.js",
  "types": "./dist/api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./bin": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "create-tailwind-styled": "./dist/index.js",
    "tailwind-styled": "./dist/index.js",
    "tw": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:dev": "tsup --config tsup.config.ts --sourcemap --watch",
    "build:release": "tsup --config tsup.config.ts --no-sourcemap",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsup --config tsup.config.ts --watch",
    "pack:check": "node ../../scripts/check-pack-artifacts.mjs packages/infrastructure/cli",
    "test": "node --test tests/*.test.mjs",
    "test:watch": "node --test --watch tests/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8",
    "typescript": "^6"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@tailwind-styled/analyzer": "^0.2.0",
    "@tailwind-styled/compiler": "^0.2.0",
    "@tailwind-styled/engine": "^0.2.0",
    "@tailwind-styled/next": "^0.2.0",
    "@tailwind-styled/rspack": "^0.2.0",
    "@tailwind-styled/scanner": "^0.2.0",
    "@tailwind-styled/shared": "^0.2.0",
    "@tailwind-styled/svelte": "^0.2.0",
    "@tailwind-styled/vite": "^0.2.0",
    "@tailwind-styled/vue": "^0.2.0",
    "commander": "^12.1.0",
    "inversify": "^8.1.0",
    "picocolors": "^1.1.1",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  }
}
