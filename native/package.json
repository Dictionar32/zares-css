{
  "name": "@tailwind-styled/native",
  "version": "5.0.0",
  "description": "Native Rust engine for tailwind-styled-v4",
  "main": "index.js",
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "artifacts": "napi artifacts --build-dir . --output-dir .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["Rust", "Tailwind CSS", "compiler", "transformer"],
  "author": "Dictionar32",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  },
  "napi": {
    "binaryName": "tailwind-styled-native",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl"
    ],
    "outputDir": ".",
    "packageName": "@tailwind-styled/native",
    "generateTypeDef": true,
    "typeDef": "../packages/domain/shared/src/generated/native.d.ts",
    "typedefHeader": "/* Auto-generated by napi-rs — DO NOT EDIT */\n/* Run: cd native && npx @napi-rs/cli build to regenerate */\n"
  }
}